# ===== Postgres (M0/M1) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rag_app
POSTGRES_PASSWORD=CHANGE_TO_..._PW
POSTGRES_DB=rag

# ===== OpenSearch (M0/M4) =====
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=CHANGE_T...RD

# ===== TEI (Text Embeddings Inference) (M0/M3) =====
TEI_URL=http://tei:80
TEI_MODEL_ID=BAAI/bge-m3
TEI_EMBED_DIM=1024
TEI_MAX_BATCH_SIZE=32

# ===== Langfuse (M0/M10) =====
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=CHANGEME_..._KEY
LANGFUSE_NEXTAUTH_SECRET=CHANGEME_nextauth
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_SALT=CHANGEME_salt
LANGFUSE_DATABASE_URL=postgresql://rag_app:CHANGE_TO_SECRET_PW@postgres:5432/rag

# ===== MinIO (M12 backup) =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=CHANGEME_minio
MINIO_BUCKET=rag-backups

# ===== App (M0) =====
APP_ENV=development
LOG_LEVEL=INFO
