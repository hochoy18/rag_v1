# RAG V1 .env.example (M0/M1/M3/M4/M10/M12 整合)
# r2 实操修订: TEI 字段名对齐 M3 plan EmbeddingSettings (url→base_url, batch_size→max_batch_size 32, dim→1024)
# r2 修复: LANGFUSE_NEXTAUTH_URL 占位补全 (前次 patch 失误截断)
# 注: *** 占位由 hermes-agent 渲染，使用时替换为 openssl rand 生成

# ===== Postgres (M0/M1) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rag_app
POSTGRES_PASSWORD=***n
# ===== OpenSearch (M0/M4) =====
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=***n
# ===== TEI (M0/M3) — 字段名对齐 M3 plan EmbeddingSettings =====
TEI_BASE_URL=http://tei:80
TEI_BATCH_SIZE=32
TEI_DIM=1024
TEI_TIMEOUT_SECONDS=60

# ===== Langfuse (M0/M10) =====
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=***
LANGFUSE_NEXTAUTH_SECRET=CHANGEME_nextauth_secret_32_chars_min
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_SALT=CHANGEME_salt_16_chars
LANGFUSE_DATABASE_URL=postgresql://rag_app:placeholder@postgres:5432/rag
n
# ===== MinIO (M12 backup) =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=***n
# ===== App (M0) =====
APP_ENV=development
LOG_LEVEL=INFO
